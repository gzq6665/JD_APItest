    {
      "name": "开通账户",
      "item": [
        {
          "name": "实名认证",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const lastNames = ['李','王','张','刘','陈','杨','赵','黄','周','吴','徐','孙','胡','朱','高','林'];\r",
                  "const firstNames = ['伟','芳','娜','敏','静','秀英','丽','强','磊','军','洋','勇','艳','杰','娟','涛','明','超','秀兰','霞','平','刚','桂英'];\r",
                  "\r",
                  "function randomItem(arr) {\r",
                  "    return arr[Math.floor(Math.random() * arr.length)];\r",
                  "}\r",
                  "\r",
                  "const fullName = randomItem(lastNames) + randomItem(firstNames);\r",
                  "\r",
                  "pm.environment.set('randomChineseName', fullName);\r",
                  "\r",
                  "console.log('随机中文姓名:', fullName);\r",
                  "\r",
                  "\r",
                  "function randomItem(arr) {\r",
                  "    return arr[Math.floor(Math.random() * arr.length)];\r",
                  "}\r",
                  "\r",
                  "function randomInt(min, max) {\r",
                  "    return Math.floor(Math.random() * (max - min + 1)) + min;\r",
                  "}\r",
                  "\r",
                  "// 常见地区码示例，可自行扩充\r",
                  "const areaCodes = [\r",
                  "    '110101', // 北京东城\r",
                  "    '110102', // 北京西城\r",
                  "    '310101', // 上海黄浦\r",
                  "    '440103', // 广州荔湾\r",
                  "    '440104', // 广州越秀\r",
                  "    '440106', // 广州天河\r",
                  "    '440303', // 深圳罗湖\r",
                  "    '440304', // 深圳福田\r",
                  "    '440305', // 深圳南山\r",
                  "    '330106', // 杭州西湖\r",
                  "    '320106', // 南京鼓楼\r",
                  "    '510107'  // 成都武侯\r",
                  "];\r",
                  "\r",
                  "// 生成出生日期 yyyyMMdd\r",
                  "const year = randomInt(1970, 2005);\r",
                  "const month = String(randomInt(1, 12)).padStart(2, '0');\r",
                  "\r",
                  "// 根据月份简单处理天数\r",
                  "let maxDay = 31;\r",
                  "if (['04', '06', '09', '11'].includes(month)) {\r",
                  "    maxDay = 30;\r",
                  "} else if (month === '02') {\r",
                  "    const isLeap = (year % 4 === 0 && year % 100 !== 0) || (year % 400 === 0);\r",
                  "    maxDay = isLeap ? 29 : 28;\r",
                  "}\r",
                  "const day = String(randomInt(1, maxDay)).padStart(2, '0');\r",
                  "\r",
                  "const birth = `${year}${month}${day}`;\r",
                  "\r",
                  "// 顺序码 3 位，最后一位奇数男/偶数女，这里随机\r",
                  "const seq = String(randomInt(1, 999)).padStart(3, '0');\r",
                  "\r",
                  "// 前17位\r",
                  "const first17 = randomItem(areaCodes) + birth + seq;\r",
                  "\r",
                  "// 校验码计算\r",
                  "const weights = [7, 9, 10, 5, 8, 4, 2, 1, 6, 3, 7, 9, 10, 5, 8, 4, 2];\r",
                  "const checkCodeMap = ['1', '0', 'X', '9', '8', '7', '6', '5', '4', '3', '2'];\r",
                  "\r",
                  "let sum = 0;\r",
                  "for (let i = 0; i < 17; i++) {\r",
                  "    sum += parseInt(first17[i], 10) * weights[i];\r",
                  "}\r",
                  "const checkCode = checkCodeMap[sum % 11];\r",
                  "\r",
                  "const randomIdCard = first17 + checkCode;\r",
                  "\r",
                  "pm.environment.set('randomIdCard', randomIdCard);\r",
                  "console.log('随机身份证号:', randomIdCard);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "pm.test(\"Body matches string\", function () {\r",
                  "    pm.expect(pm.response.text()).to.include(\"提交成功\");\r",
                  "});\r",
                  "pm.test(\"status\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.status).to.eql(200);\r",
                  "});\r",
                  "\r",
                  "pm.environment.set(\"card_id666\", pm.response.json().data.card_id);\r",
                  "pm.environment.set(\"realname666\", pm.response.json().data.realname);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "multipart/form-data",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "realname",
                  "value": "{{randomChineseName}}",
                  "type": "text",
                  "uuid": "ec2cef64-8098-4ae4-9d9d-32b4e2a01ee0"
                },
